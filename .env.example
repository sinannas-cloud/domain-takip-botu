# Telegram'da @BotFather ile olusturulan botun anahtari
TELEGRAM_BOT_TOKEN=

# Bildirimlerin gidecegi kullanici veya grup kimligi
TELEGRAM_CHAT_ID=

# Kontroller arasindaki sure
CHECK_INTERVAL_MINUTES=15

# Ayni anda yapilacak azami RDAP sorgusu
CHECK_CONCURRENCY=3

# Her bir HTTP isteginin zaman asimi
REQUEST_TIMEOUT_MS=15000
